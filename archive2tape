#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)/$(basename "${BASH_SOURCE[0]}")"
DEFAULT_INCLUDES=("*.nc" "*.zarr" "*.grb" "*.grib" "*.grb2" "*.grib2")
ONE_GIB=$((1024 * 1024 * 1024))
TEN_GIB=$((10 * ONE_GIB))
TWO_HUNDRED_GIB=$((200 * ONE_GIB))
THREE_TIB=$((3 * 1024 * ONE_GIB))

die() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
warn() { printf 'WARNING: %s\n' "$*" >&2; }
info() { printf '%s\n' "$*"; }

usage() {
    cat <<'EOF'
Usage:
  archive2tape put SOURCE_DIR ARCHIVE_DIR --project PROJECT [--work WORK_DIR] [--config FILE]
  archive2tape get ARCHIVE_DIR TARGET_DIR --project PROJECT [--work WORK_DIR] [--config FILE]

Stage commands:
  archive2tape pack SOURCE_DIR WORK_DIR --project PROJECT
  archive2tape archive WORK_DIR ARCHIVE_DIR --project PROJECT
  archive2tape retrieve ARCHIVE_DIR WORK_DIR --project PROJECT
  archive2tape unpack WORK_DIR TARGET_DIR

Common options:
  --config FILE                 Read defaults from archive2tape.conf-style KEY=VALUE file
  --project PROJECT              Slurm/HSM project, must match /arch/<PROJECT>/...
  --account ACCOUNT              Slurm account; defaults to PROJECT
  --work WORK_DIR                Work dir for put/get; defaults to $GRAVEYARD/<dataset>
  --include GLOB                 Add selected pattern; defaults include nc, zarr, grib
  --include-hidden               Allow hidden paths when selecting files
  --dry-run                      Print plan without submitting or unpacking
  --run-now                      Run pack/archive/unpack worker in current shell
  --all-objects                  Without a manifest, archive/unpack all local *.tar.zst objects
  --allow-non-scratch-work       Allow work dir outside /scratch
  --allow-huge                   Allow archive object plan above 3 TiB
  --overwrite                    Replace existing local tar object
  --log-dir DIR                  Slurm log dir; default WORK_DIR/.slurm
  --help                         Show this help

Beginner workflow:
    PROJECT=ab1234  # replace with your project
    archive2tape put model_output_dir "/arch/$PROJECT/$USER/my_run" --project "$PROJECT" --work "$GRAVEYARD/my_run"
    archive2tape get "/arch/$PROJECT/$USER/my_run" model_output_from_archive --project "$PROJECT" --work "$GRAVEYARD/my_run"
EOF
}

shell_quote() { printf '%q' "$1"; }
require_cmd() { command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"; }
line_count() { awk 'END{print NR+0}' "$1"; }
sum_second_column() { awk -F '\t' '{s+=$2} END{printf "%.0f\n", s+0}' "$1"; }
dir_abs() { cd "$1" && pwd -P; }
file_size() { stat -c%s "$1" 2>/dev/null || stat -f%z "$1" 2>/dev/null || echo 0; }
dir_size() { du -sb "$1" 2>/dev/null | awk '{print $1}' || du -sk "$1" | awk '{print $1 * 1024}'; }
utc_now() { date -u +%Y-%m-%dT%H:%M:%SZ; }
trim_ws() { awk '{$1=$1; print}' <<< "$1"; }
expand_config_value() { printf '%s\n' "${1//\$USER/${USER:-}}"; }

human_bytes() {
    awk -v bytes="$1" 'BEGIN {
        split("B KiB MiB GiB TiB PiB", unit)
        value = bytes + 0
        i = 1
        while (value >= 1024 && i < 6) { value /= 1024; i++ }
        if (i == 1) printf "%.0f %s", value, unit[i]
        else printf "%.1f %s", value, unit[i]
    }'
}

archive_project() {
    local ns="$1" rest project
    [[ "$ns" == /arch/*/* ]] || return 1
    rest="${ns#/arch/}"
    project="${rest%%/*}"
    [[ -n "$project" ]] || return 1
    printf '%s\n' "$project"
}

# DKRZ calls archive directories "namespaces"; user-facing text says ARCHIVE_DIR.
validate_archive_ns() {
    local ns="$1" project="$2" ns_project
    ns_project="$(archive_project "$ns")" || die "ARCHIVE_DIR must look like /arch/<project>/... (got '$ns')."
    [[ -n "$project" ]] || die "--project is required for ARCHIVE_DIR '$ns'."
    [[ "$ns_project" == "$project" ]] || die "--project '$project' does not match ARCHIVE_DIR project '$ns_project'."
}

resolve_archive_dir() {
    local archive_ns="$1"
    if [[ "$archive_ns" == /arch/* ]]; then
        printf '%s\n' "$archive_ns"
    elif [[ -n "$ARCHIVE_ROOT" ]]; then
        printf '%s/%s\n' "${ARCHIVE_ROOT%/}" "$archive_ns"
    else
        printf '%s\n' "$archive_ns"
    fi
}

validate_work_dir() {
    local work_dir="$1" allow="$2" dry_run="$3"
    [[ -n "$work_dir" ]] || die "Missing work directory. Pass --work or set GRAVEYARD."
    if [[ "$work_dir" != /scratch/* && "$allow" -ne 1 ]]; then
        if [[ "$dry_run" -eq 1 ]]; then
            warn "Work dir is outside /scratch: $work_dir"
        else
            die "Work dir must be under /scratch by default. Use --allow-non-scratch-work to override."
        fi
    fi
}

resolve_put_get_work_dir() {
    local archive_ns="$1" explicit_work="$2" dataset
    if [[ -n "$explicit_work" ]]; then
        printf '%s\n' "$explicit_work"
        return
    fi
    dataset="$(basename "${archive_ns%/}")"
    if [[ -n "$WORK_ROOT" ]]; then
        printf '%s/%s\n' "${WORK_ROOT%/}" "$dataset"
        return
    fi
    [[ -n "${GRAVEYARD:-}" ]] || die "Pass --work WORK_DIR, set WORK_ROOT in config, or set GRAVEYARD."
    printf '%s/%s\n' "${GRAVEYARD%/}" "$dataset"
}

path_matches_include() {
    local rel="$1" pattern
    for pattern in "${INCLUDES[@]}"; do
        [[ "$rel" == $pattern ]] && return 0
    done
    return 1
}

is_hidden_path() {
    local rel="$1"
    [[ "$rel" == .* || "$rel" == */.* ]]
}

is_under_selected_dir() {
    local rel="$1" selected_dir
    shift || true
    for selected_dir in "$@"; do
        [[ "$rel" == "$selected_dir"/* ]] && return 0
    done
    return 1
}

path_size() {
    local path="$1"
    if [[ -d "$path" ]]; then
        dir_size "$path"
    else
        file_size "$path"
    fi
}

collect_selected_paths() {
    local source_dir="$1" tar_list="$2" manifest="$3"
    local rel path type size
    local selected_dirs=()
    : > "$tar_list"
    : > "$manifest"
    while IFS= read -r -d '' path; do
        rel="${path#./}"
        if ((${#selected_dirs[@]} > 0)) && is_under_selected_dir "$rel" "${selected_dirs[@]}"; then
            continue
        fi
        if [[ "$INCLUDE_HIDDEN" -ne 1 ]] && is_hidden_path "$rel"; then
            continue
        fi
        path_matches_include "$rel" || continue
        if [[ -d "$source_dir/$rel" ]]; then
            type="dir"
            selected_dirs+=("$rel")
        else
            type="file"
        fi
        size="$(path_size "$source_dir/$rel")"
        printf '%s\n' "$rel" >> "$tar_list"
        printf '%s\t%s\t%s\n' "$type" "$size" "$rel" >> "$manifest"
    done < <(
        cd "$source_dir"
        find . -mindepth 1 -print0
    )
}

write_metadata() {
    local metadata="$1" source_dir="$2" archive_ns="$3" project="$4" account="$5" tar_object="$6" total_bytes="$7"
    {
        printf 'ARCHIVE2TAPE_VERSION=%s\n' "$VERSION"
        printf 'CREATED_UTC=%s\n' "$(utc_now)"
        printf 'PROJECT=%s\n' "$project"
        printf 'ACCOUNT=%s\n' "$account"
        printf 'SOURCE_DIR=%s\n' "$source_dir"
        printf 'SOURCE_BASENAME=%s\n' "$(basename "$source_dir")"
        printf 'ARCHIVE_DIR=%s\n' "$archive_ns"
        printf 'TAR_OBJECT=%s\n' "$(basename "$tar_object")"
        printf 'TOTAL_BYTES=%s\n' "$total_bytes"
        printf 'INCLUDE_PATTERNS=%s\n' "${INCLUDES[*]}"
    } > "$metadata"
}

print_size_warnings() {
    local total_bytes="$1" allow_huge="$2"
    if (( total_bytes < ONE_GIB )); then
        warn "Planned archive object is below 1 GiB ($(human_bytes "$total_bytes")); tape quota/retrieval may be inefficient."
    elif (( total_bytes < TEN_GIB )); then
        warn "Planned archive object is below DKRZ's ideal 10-200 GiB range ($(human_bytes "$total_bytes"))."
    elif (( total_bytes > TWO_HUNDRED_GIB )); then
        warn "Planned archive object is above DKRZ's ideal 10-200 GiB range ($(human_bytes "$total_bytes"))."
    fi
    if (( total_bytes > THREE_TIB && allow_huge != 1 )); then
        die "Planned archive object is above 3 TiB ($(human_bytes "$total_bytes")). Re-run with --allow-huge if intentional."
    fi
}

prepare_pack_plan() {
    local source_dir="$1" work_dir="$2" archive_ns="$3" project="$4" account="$5" dry_run="$6"
    local dataset tar_object tar_list manifest metadata archive_manifest total_bytes file_count
    source_dir="$(dir_abs "$source_dir")"
    dataset="$(basename "${archive_ns:-$source_dir}")"
    dataset="${dataset%/}"
    tar_object="$work_dir/${dataset}_0001.tar.zst"
    tar_list="$work_dir/archive2tape_tar_paths.txt"
    manifest="$work_dir/archive2tape_manifest.tsv"
    metadata="$work_dir/archive2tape_metadata.env"
    archive_manifest="$work_dir/archive2tape_archive_objects.txt"

    if [[ "$dry_run" -eq 1 ]]; then
        local tmp_dir
        tmp_dir="$(mktemp -d)"
        tar_list="$tmp_dir/tar_paths.txt"
        manifest="$tmp_dir/manifest.tsv"
        archive_manifest="$tmp_dir/archive_objects.txt"
    else
        mkdir -p "$work_dir"
    fi

    collect_selected_paths "$source_dir" "$tar_list" "$manifest"
    file_count="$(line_count "$tar_list")"
    [[ "$file_count" -gt 0 ]] || die "No selected files found below '$source_dir'. Add --include PATTERN if needed."
    total_bytes="$(sum_second_column "$manifest")"
    print_size_warnings "$total_bytes" "$ALLOW_HUGE"

    if [[ "$dry_run" -ne 1 ]]; then
        write_metadata "$metadata" "$source_dir" "$archive_ns" "$project" "$account" "$tar_object" "$total_bytes"
        {
            printf '%s\n' "$tar_object"
            printf '%s\n' "$manifest"
            printf '%s\n' "$tar_list"
            printf '%s\n' "$metadata"
        } > "$archive_manifest"
    fi

    info "SOURCE_DIR=$source_dir"
    info "WORK_DIR=$work_dir"
    [[ -n "$archive_ns" ]] && info "ARCHIVE_DIR=$archive_ns"
    [[ -n "$project" ]] && info "PROJECT=$project"
    [[ -n "$account" ]] && info "ACCOUNT=$account"
    info "SELECTED_ENTRIES=$file_count"
    info "SELECTED_SIZE=$(human_bytes "$total_bytes")"
    info "TAR_OBJECT=$tar_object"
    info "MANIFEST=$manifest"
    info "TAR_LIST=$tar_list"
    info "ARCHIVE_OBJECTS=$archive_manifest"
}

create_archive_manifest_from_work_dir() {
    local work_dir="$1" archive_manifest="$2" tar_count tar_file
    local tar_files=()
    if [[ -s "$archive_manifest" ]]; then
        validate_archive_manifest_files "$archive_manifest"
        warn_for_extra_tar_objects "$work_dir" "$archive_manifest"
        return
    fi
    while IFS= read -r tar_file; do
        tar_files+=("$tar_file")
    done < <(find "$work_dir" -maxdepth 1 -type f -name '*.tar.zst' | sort)
    if [[ "${#tar_files[@]}" -gt 1 && "$ALL_OBJECTS" -ne 1 ]]; then
        die "Multiple .tar.zst files found in '$work_dir'. Use existing archive2tape_archive_objects.txt or pass --all-objects."
    fi
    : > "$archive_manifest"
    ((${#tar_files[@]} > 0)) && printf '%s\n' "${tar_files[@]}" >> "$archive_manifest"
    for meta in archive2tape_manifest.tsv archive2tape_tar_paths.txt archive2tape_metadata.env; do
        [[ -f "$work_dir/$meta" ]] && printf '%s\n' "$work_dir/$meta" >> "$archive_manifest"
    done
    tar_count="$(grep -c '\.tar\.zst$' "$archive_manifest" || true)"
    [[ "$tar_count" -gt 0 ]] || die "No .tar.zst files found in '$work_dir'."
    validate_archive_manifest_files "$archive_manifest"
}

validate_archive_manifest_files() {
    local archive_manifest="$1" path tar_count=0
    [[ -f "$archive_manifest" ]] || die "Missing archive object manifest: $archive_manifest"
    while IFS= read -r path; do
        [[ -n "$path" ]] || continue
        [[ -f "$path" ]] || die "Manifest object is missing locally: $path"
        [[ "$path" == *.tar.zst ]] && tar_count=$((tar_count + 1))
    done < "$archive_manifest"
    [[ "$tar_count" -gt 0 ]] || die "No .tar.zst files listed in '$archive_manifest'."
}

warn_for_extra_tar_objects() {
    local work_dir="$1" archive_manifest="$2" tar_file
    while IFS= read -r tar_file; do
        if ! grep -Fxq "$tar_file" "$archive_manifest"; then
            warn "Ignoring extra tar object not listed in manifest: $tar_file"
        fi
    done < <(find "$work_dir" -maxdepth 1 -type f -name '*.tar.zst' | sort)
}

submit_pack_job() {
    local source_dir="$1" tar_list="$2" tar_object="$3" log_dir="$4" account="$5" job_id
    mkdir -p "$log_dir"
    require_cmd sbatch
    job_id="$(
        sbatch --parsable \
            --job-name=a2t_pack \
            --partition="${PACK_PARTITION:-compute}" \
            --nodes=1 \
            --ntasks=1 \
            --cpus-per-task="${PACK_CPUS:-8}" \
            --time="${PACK_TIME:-04:00:00}" \
            --account="$account" \
            --mem="${PACK_MEM:-16G}" \
            --output="$log_dir/pack_%j.out" \
            --error="$log_dir/pack_%j.err" <<EOF
#!/usr/bin/env bash
set -euo pipefail
$(shell_quote "$SCRIPT_PATH") __worker_pack $(shell_quote "$source_dir") $(shell_quote "$tar_list") $(shell_quote "$tar_object") $(shell_quote "$OVERWRITE")
EOF
    )"
    printf '%s\n' "${job_id%%;*}"
}

submit_archive_job() {
    local archive_manifest="$1" archive_ns="$2" log_dir="$3" account="$4" dependency="${5:-}" job_id dep_args=()
    mkdir -p "$log_dir"
    require_cmd sbatch
    [[ -n "$dependency" ]] && dep_args=(--dependency="afterok:$dependency")
    job_id="$(
        sbatch --parsable \
            "${dep_args[@]}" \
            --job-name=a2t_archive \
            --partition="${ARCHIVE_PARTITION:-shared}" \
            --nodes=1 \
            --ntasks=1 \
            --cpus-per-task=1 \
            --time="${ARCHIVE_TIME:-08:00:00}" \
            --account="$account" \
            --mem="${ARCHIVE_MEM:-8G}" \
            --output="$log_dir/archive_%j.out" \
            --error="$log_dir/archive_%j.err" <<EOF
#!/usr/bin/env bash
set -euo pipefail
$(shell_quote "$SCRIPT_PATH") __worker_archive $(shell_quote "$archive_manifest") $(shell_quote "$archive_ns")
EOF
    )"
    printf '%s\n' "${job_id%%;*}"
}

submit_retrieve_job() {
    local archive_ns="$1" work_dir="$2" log_dir="$3" account="$4" job_id
    mkdir -p "$log_dir"
    require_cmd sbatch
    job_id="$(
        sbatch --parsable \
            --job-name=a2t_retrieve \
            --partition="${RETRIEVE_PARTITION:-shared}" \
            --nodes=1 \
            --ntasks=1 \
            --cpus-per-task=1 \
            --time="${RETRIEVE_TIME:-08:00:00}" \
            --account="$account" \
            --mem="${RETRIEVE_MEM:-8G}" \
            --output="$log_dir/retrieve_%j.out" \
            --error="$log_dir/retrieve_%j.err" <<EOF
#!/usr/bin/env bash
set -euo pipefail
$(shell_quote "$SCRIPT_PATH") __worker_retrieve $(shell_quote "$archive_ns") $(shell_quote "$work_dir") $(shell_quote "$account")
EOF
    )"
    printf '%s\n' "${job_id%%;*}"
}

load_levante_and_slk() {
    [[ -f /sw/etc/profile.levante ]] && . /sw/etc/profile.levante
    command -v module >/dev/null 2>&1 && module load slk >/dev/null 2>&1 || true
    require_cmd slk
    require_cmd slk_helpers
    [[ -f "${HOME}/.slk/config.json" ]] || die "Run 'module load slk && slk login' first."
}

worker_pack() {
    local source_dir="$1" tar_list="$2" tar_object="$3" overwrite="$4" tmp_object threads
    require_cmd tar
    require_cmd zstd
    [[ -d "$source_dir" ]] || die "Missing source dir: $source_dir"
    [[ -f "$tar_list" ]] || die "Missing tar path list: $tar_list"
    if [[ -e "$tar_object" && "$overwrite" -ne 1 ]]; then
        die "Tar object exists: $tar_object (use --overwrite to replace)"
    fi
    mkdir -p "$(dirname "$tar_object")"
    tmp_object="${tar_object}.tmp.$$"
    rm -f "$tmp_object"
    trap 'rm -f "$tmp_object"' EXIT
    threads="${SLURM_CPUS_PER_TASK:-1}"
    tar -C "$source_dir" -cf - -T "$tar_list" | zstd -T"$threads" -9 -o "$tmp_object"
    mv "$tmp_object" "$tar_object"
    trap - EXIT
    info "PACKED=$tar_object"
}

worker_archive() {
    local archive_manifest="$1" archive_ns="${2%/}/" code path
    local files=()
    while IFS= read -r path; do
        [[ -n "$path" ]] && files+=("$path")
    done < "$archive_manifest"
    [[ "${#files[@]}" -gt 0 ]] || die "Archive manifest is empty: $archive_manifest"
    load_levante_and_slk
    set +e
    slk archive -vv "${files[@]}" "$archive_ns"
    code=$?
    set -e
    if [[ "$code" -ne 0 ]]; then
        warn "slk archive failed with exit code $code. Re-run the same archive command after checking ~/.slk/slk-cli.log."
    fi
    return "$code"
}

list_remote_tar_objects() {
    local archive_ns="${1%/}"
    slk list "$archive_ns" | awk -v ns="$archive_ns" '
        /\.tar\.zst/ {
            for (i = 1; i <= NF; i++) {
                if ($i ~ /\.tar\.zst$/) print ns "/" $i
            }
        }
    '
}

expected_remote_tar_objects() {
    local archive_ns="${1%/}" work_dir="$2" metadata="$2/archive2tape_metadata.env" archive_manifest="$2/archive2tape_archive_objects.txt"
    local tar_object path count=0
    if [[ -f "$metadata" ]]; then
        tar_object="$(awk -F= '$1 == "TAR_OBJECT" {print $2; exit}' "$metadata")"
        [[ -n "$tar_object" ]] && { printf '%s/%s\n' "$archive_ns" "$tar_object"; return 0; }
    fi
    if [[ -f "$archive_manifest" ]]; then
        while IFS= read -r path; do
            if [[ "$path" == *.tar.zst ]]; then
                printf '%s/%s\n' "$archive_ns" "$(basename "$path")"
                count=$((count + 1))
            fi
        done < "$archive_manifest"
        [[ "$count" -gt 0 ]] && return 0
    fi
    return 1
}

worker_retrieve() {
    local archive_ns="$1" work_dir="$2" account="$3" count watcher_dir object
    local objects=()
    mkdir -p "$work_dir"
    load_levante_and_slk
    while IFS= read -r object; do
        [[ -n "$object" ]] && objects+=("$object")
    done < <(expected_remote_tar_objects "$archive_ns" "$work_dir" || list_remote_tar_objects "$archive_ns")
    count="${#objects[@]}"
    [[ "$count" -gt 0 ]] || die "No .tar.zst objects found in ARCHIVE_DIR: $archive_ns"
    if (( count <= 4 )); then
        slk_helpers recall "${objects[@]}" -d "$work_dir"
        slk_helpers retrieve "${objects[@]}" -d "$work_dir" -v --slurm "$account"
    else
        watcher_dir="$work_dir/archive2tape_watchers_$(date +%Y%m%d_%H%M%S)"
        mkdir -p "$watcher_dir"
        (
            cd "$watcher_dir"
            slk_helpers init_watchers "${objects[@]}" -d "$work_dir" -ns
            slk_helpers start_watchers "$account"
        )
        info "WATCHER_DIR=$watcher_dir"
    fi
    info "Retrieval started. After retrieved .tar.zst files are present, run:"
    info "  archive2tape unpack $(shell_quote "$work_dir") TARGET_DIR"
}

worker_unpack() {
    local work_dir="$1" target_dir="$2" archive_manifest="${3:-$1/archive2tape_archive_objects.txt}" all_objects="${4:-0}" tar_file count=0
    local tar_files=()
    require_cmd tar
    require_cmd zstd
    mkdir -p "$target_dir"
    while IFS= read -r tar_file; do
        [[ -n "$tar_file" ]] && tar_files+=("$tar_file")
    done < <(select_local_tar_objects "$work_dir" "$archive_manifest" "$all_objects")
    if ((${#tar_files[@]} > 0)); then
        for tar_file in "${tar_files[@]}"; do
            count=$((count + 1))
            zstd -dc "$tar_file" | tar -xf - -C "$target_dir"
            info "UNPACKED=$tar_file"
        done
    fi
    [[ "$count" -gt 0 ]] || die "No .tar.zst files found in '$work_dir'."
}

select_local_tar_objects() {
    local work_dir="$1" archive_manifest="$2" all_objects="$3"
    local tar_file
    local tar_files=()
    if [[ -s "$archive_manifest" ]]; then
        while IFS= read -r tar_file; do
            [[ "$tar_file" == *.tar.zst ]] || continue
            [[ -f "$tar_file" ]] || die "Manifest tar object is missing locally: $tar_file"
            printf '%s\n' "$tar_file"
        done < "$archive_manifest"
        return
    fi
    while IFS= read -r tar_file; do
        tar_files+=("$tar_file")
    done < <(find "$work_dir" -maxdepth 1 -type f -name '*.tar.zst' | sort)
    if [[ "${#tar_files[@]}" -gt 1 && "$all_objects" -ne 1 ]]; then
        die "Multiple .tar.zst files found in '$work_dir'. Pass --all-objects if all belong to this restore."
    fi
    ((${#tar_files[@]} > 0)) && printf '%s\n' "${tar_files[@]}"
}

dry_run_remote_objects() {
    local archive_ns="$1" work_dir="$2"
    if expected_remote_tar_objects "$archive_ns" "$work_dir"; then
        return
    fi
    if command -v slk >/dev/null 2>&1 && [[ -f "${HOME}/.slk/config.json" ]]; then
        list_remote_tar_objects "$archive_ns" || true
    else
        info "(remote listing skipped: slk login not available in this environment)"
    fi
}

find_config_arg() {
    local arg
    while [[ $# -gt 0 ]]; do
        arg="$1"
        case "$arg" in
            --config)
                [[ -n "${2:-}" ]] || die "--config requires a value"
                printf '%s\n' "$2"
                return
                ;;
            --config=*)
                printf '%s\n' "${arg#--config=}"
                return
                ;;
        esac
        shift
    done
}

validate_config_value() {
    local key="$1" value="$2" without_user
    [[ "$value" != *'$('* ]] || die "Config key '$key' contains command substitution."
    [[ "$value" != *'`'* ]] || die "Config key '$key' contains backticks."
    [[ "$value" != *';'* && "$value" != *'&&'* && "$value" != *'||'* ]] || die "Config key '$key' contains shell control syntax."
    [[ "$value" != *'|'* && "$value" != *'<'* && "$value" != *'>'* ]] || die "Config key '$key' contains shell redirection or pipe syntax."
    without_user="${value//\$USER/}"
    [[ "$without_user" != *'$'* ]] || die "Config key '$key' uses unsupported variable expansion; only \$USER is allowed."
}

apply_config_key() {
    local key="$1" value="$2"
    [[ -n "$value" ]] || die "Config key '$key' has an empty value."
    value="$(expand_config_value "$value")"
    case "$key" in
        PROJECT) PROJECT="$value" ;;
        ACCOUNT) ACCOUNT="$value" ;;
        WORK_ROOT) WORK_ROOT="$value" ;;
        ARCHIVE_ROOT) ARCHIVE_ROOT="$value" ;;
        INCLUDE_PATTERNS) read -r -a INCLUDES <<< "$value" ;;
        ALLOW_NON_SCRATCH_WORK)
            [[ "$value" == 0 || "$value" == 1 ]] || die "Config key '$key' must be 0 or 1."
            ALLOW_NON_SCRATCH_WORK="$value"
            ;;
        INCLUDE_HIDDEN)
            [[ "$value" == 0 || "$value" == 1 ]] || die "Config key '$key' must be 0 or 1."
            INCLUDE_HIDDEN="$value"
            ;;
        *) die "Unknown config key: $key" ;;
    esac
}

load_config() {
    local config_file="$1" raw_line line key value
    local seen_keys=()
    [[ -f "$config_file" ]] || die "Missing config file: $config_file"
    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        line="${raw_line%%#*}"
        line="$(trim_ws "$line")"
        [[ -z "$line" ]] && continue
        [[ "$line" == *=* ]] || die "Config line must be KEY=VALUE: $raw_line"
        key="$(trim_ws "${line%%=*}")"
        value="$(trim_ws "${line#*=}")"
        if [[ "$value" == \"*\" && "$value" == *\" ]]; then
            value="${value:1:${#value}-2}"
        elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
            value="${value:1:${#value}-2}"
        fi
        [[ "$key" =~ ^[A-Z][A-Z0-9_]*$ ]] || die "Invalid config key: $key"
        if ((${#seen_keys[@]} > 0)) && printf '%s\n' "${seen_keys[@]}" | grep -Fxq "$key"; then
            die "Duplicate config key: $key"
        fi
        seen_keys+=("$key")
        validate_config_value "$key" "$value"
        apply_config_key "$key" "$value"
    done < "$config_file"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
    exit 0
fi

COMMAND="${1:-}"
case "$COMMAND" in
    __worker_pack) shift; worker_pack "$@"; exit ;;
    __worker_archive) shift; worker_archive "$@"; exit ;;
    __worker_retrieve) shift; worker_retrieve "$@"; exit ;;
    __worker_unpack) shift; worker_unpack "$@"; exit ;;
esac

[[ -n "$COMMAND" ]] || { usage; exit 1; }
shift || true

PROJECT=""
ACCOUNT=""
WORK=""
WORK_ROOT=""
ARCHIVE_ROOT=""
CONFIG=""
LOG_DIR=""
DRY_RUN=0
RUN_NOW=0
ALLOW_NON_SCRATCH_WORK=0
ALLOW_HUGE=0
INCLUDE_HIDDEN=0
OVERWRITE=0
ALL_OBJECTS=0
INCLUDES=("${DEFAULT_INCLUDES[@]}")
POSITIONAL=()

CONFIG="$(find_config_arg "$@")"
[[ -n "$CONFIG" ]] && load_config "$CONFIG"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --config) CONFIG="${2:-}"; [[ -n "$CONFIG" ]] || die "--config requires a value"; shift 2 ;;
        --config=*) CONFIG="${1#--config=}"; [[ -n "$CONFIG" ]] || die "--config requires a value"; shift ;;
        --project) PROJECT="${2:-}"; [[ -n "$PROJECT" ]] || die "--project requires a value"; shift 2 ;;
        --account) ACCOUNT="${2:-}"; [[ -n "$ACCOUNT" ]] || die "--account requires a value"; shift 2 ;;
        --work) WORK="${2:-}"; [[ -n "$WORK" ]] || die "--work requires a value"; shift 2 ;;
        --log-dir) LOG_DIR="${2:-}"; [[ -n "$LOG_DIR" ]] || die "--log-dir requires a value"; shift 2 ;;
        --include) INCLUDES+=("${2:-}"); [[ -n "${2:-}" ]] || die "--include requires a value"; shift 2 ;;
        --include-hidden) INCLUDE_HIDDEN=1; shift ;;
        --dry-run) DRY_RUN=1; shift ;;
        --run-now) RUN_NOW=1; shift ;;
        --all-objects) ALL_OBJECTS=1; shift ;;
        --allow-non-scratch-work) ALLOW_NON_SCRATCH_WORK=1; shift ;;
        --allow-huge) ALLOW_HUGE=1; shift ;;
        --overwrite) OVERWRITE=1; shift ;;
        -h|--help) usage; exit 0 ;;
        --) shift; while [[ $# -gt 0 ]]; do POSITIONAL+=("$1"); shift; done ;;
        --*) die "Unknown option: $1" ;;
        *) POSITIONAL+=("$1"); shift ;;
    esac
done

case "$COMMAND" in
    put|pack|archive|retrieve|get|unpack) ;;
    *) usage; die "Unknown command: $COMMAND" ;;
esac

ACCOUNT="${ACCOUNT:-$PROJECT}"

cmd_pack() {
    [[ "${#POSITIONAL[@]}" -eq 2 ]] || die "Usage: archive2tape pack SOURCE_DIR WORK_DIR --project PROJECT"
    [[ -n "$PROJECT" ]] || die "--project is required for pack."
    local source_dir="${POSITIONAL[0]}" work_dir="${POSITIONAL[1]}" log_dir job_id source_abs tar_object
    [[ -d "$source_dir" ]] || die "Missing source dir: $source_dir"
    validate_work_dir "$work_dir" "$ALLOW_NON_SCRATCH_WORK" "$DRY_RUN"
    log_dir="${LOG_DIR:-$work_dir/.slurm}"
    prepare_pack_plan "$source_dir" "$work_dir" "" "$PROJECT" "$ACCOUNT" "$DRY_RUN"
    [[ "$DRY_RUN" -eq 1 ]] && return 0
    source_abs="$(dir_abs "$source_dir")"
    tar_object="$work_dir/$(basename "$source_abs")_0001.tar.zst"
    if [[ "$RUN_NOW" -eq 1 ]]; then
        worker_pack "$source_abs" "$work_dir/archive2tape_tar_paths.txt" "$tar_object" "$OVERWRITE"
    else
        job_id="$(submit_pack_job "$source_abs" "$work_dir/archive2tape_tar_paths.txt" "$tar_object" "$log_dir" "$ACCOUNT")"
        info "PACK_JOB_ID=$job_id"
        info "LOG_DIR=$log_dir"
    fi
}

cmd_archive() {
    [[ "${#POSITIONAL[@]}" -eq 2 ]] || die "Usage: archive2tape archive WORK_DIR ARCHIVE_DIR --project PROJECT"
    [[ -n "$PROJECT" ]] || die "--project is required for archive."
    local work_dir="${POSITIONAL[0]}" archive_ns="${POSITIONAL[1]}" log_dir archive_manifest job_id
    archive_ns="$(resolve_archive_dir "$archive_ns")"
    validate_archive_ns "$archive_ns" "$PROJECT"
    validate_work_dir "$work_dir" "$ALLOW_NON_SCRATCH_WORK" "$DRY_RUN"
    archive_manifest="$work_dir/archive2tape_archive_objects.txt"
    log_dir="${LOG_DIR:-$work_dir/.slurm}"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        info "WORK_DIR=$work_dir"
        info "ARCHIVE_DIR=$archive_ns"
        info "PROJECT=$PROJECT"
        info "ACCOUNT=$ACCOUNT"
        info "Would archive these local objects:"
        if [[ -s "$archive_manifest" ]]; then
            info "OBJECT_SOURCE=$archive_manifest"
            while IFS= read -r path; do [[ -n "$path" ]] && info "$path"; done < "$archive_manifest"
        else
            info "OBJECT_SOURCE=work-dir scan"
            select_local_tar_objects "$work_dir" "$archive_manifest" "$ALL_OBJECTS" || true
            find "$work_dir" -maxdepth 1 -type f \( -name 'archive2tape_*.tsv' -o -name 'archive2tape_*.txt' -o -name 'archive2tape_*.env' \) | sort || true
        fi
        return 0
    fi
    create_archive_manifest_from_work_dir "$work_dir" "$archive_manifest"
    if [[ "$RUN_NOW" -eq 1 ]]; then
        worker_archive "$archive_manifest" "$archive_ns"
    else
        job_id="$(submit_archive_job "$archive_manifest" "$archive_ns" "$log_dir" "$ACCOUNT")"
        info "ARCHIVE_JOB_ID=$job_id"
        info "ARCHIVE_OBJECTS=$archive_manifest"
        info "LOG_DIR=$log_dir"
    fi
}

cmd_put() {
    [[ "${#POSITIONAL[@]}" -eq 2 ]] || die "Usage: archive2tape put SOURCE_DIR ARCHIVE_DIR --project PROJECT [--work WORK_DIR]"
    [[ -n "$PROJECT" ]] || die "--project is required for put."
    local source_dir="${POSITIONAL[0]}" archive_ns="${POSITIONAL[1]}" work_dir log_dir pack_job archive_job archive_manifest tar_object source_abs
    [[ -d "$source_dir" ]] || die "Missing source dir: $source_dir"
    archive_ns="$(resolve_archive_dir "$archive_ns")"
    validate_archive_ns "$archive_ns" "$PROJECT"
    work_dir="$(resolve_put_get_work_dir "$archive_ns" "$WORK")"
    validate_work_dir "$work_dir" "$ALLOW_NON_SCRATCH_WORK" "$DRY_RUN"
    log_dir="${LOG_DIR:-$work_dir/.slurm}"
    prepare_pack_plan "$source_dir" "$work_dir" "$archive_ns" "$PROJECT" "$ACCOUNT" "$DRY_RUN"
    [[ "$DRY_RUN" -eq 1 ]] && return 0
    archive_manifest="$work_dir/archive2tape_archive_objects.txt"
    tar_object="$work_dir/$(basename "${archive_ns%/}")_0001.tar.zst"
    source_abs="$(dir_abs "$source_dir")"
    if [[ "$RUN_NOW" -eq 1 ]]; then
        worker_pack "$source_abs" "$work_dir/archive2tape_tar_paths.txt" "$tar_object" "$OVERWRITE"
        worker_archive "$archive_manifest" "$archive_ns"
    else
        pack_job="$(submit_pack_job "$source_abs" "$work_dir/archive2tape_tar_paths.txt" "$tar_object" "$log_dir" "$ACCOUNT")"
        archive_job="$(submit_archive_job "$archive_manifest" "$archive_ns" "$log_dir" "$ACCOUNT" "$pack_job")"
        info "PACK_JOB_ID=$pack_job"
        info "ARCHIVE_JOB_ID=$archive_job"
        info "ARCHIVE_DEPENDENCY=afterok:$pack_job"
        info "LOG_DIR=$log_dir"
    fi
}

cmd_retrieve() {
    [[ "${#POSITIONAL[@]}" -eq 2 ]] || die "Usage: archive2tape retrieve ARCHIVE_DIR WORK_DIR --project PROJECT"
    [[ -n "$PROJECT" ]] || die "--project is required for retrieve."
    local archive_ns="${POSITIONAL[0]}" work_dir="${POSITIONAL[1]}" log_dir job_id
    archive_ns="$(resolve_archive_dir "$archive_ns")"
    validate_archive_ns "$archive_ns" "$PROJECT"
    validate_work_dir "$work_dir" "$ALLOW_NON_SCRATCH_WORK" "$DRY_RUN"
    [[ "$RUN_NOW" -eq 1 ]] && die "--run-now is not supported for retrieve/get; use the default Slurm-backed retrieval workflow."
    log_dir="${LOG_DIR:-$work_dir/.slurm}"
    info "ARCHIVE_DIR=$archive_ns"
    info "WORK_DIR=$work_dir"
    info "PROJECT=$PROJECT"
    info "ACCOUNT=$ACCOUNT"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        info "Would retrieve these remote tar objects:"
        dry_run_remote_objects "$archive_ns" "$work_dir"
        return 0
    fi
    job_id="$(submit_retrieve_job "$archive_ns" "$work_dir" "$log_dir" "$ACCOUNT")"
    info "RETRIEVE_JOB_ID=$job_id"
    info "LOG_DIR=$log_dir"
    info "Retrieval can continue asynchronously. After complete .tar.zst files are present, run:"
    info "  archive2tape unpack $(shell_quote "$work_dir") TARGET_DIR"
}

cmd_get() {
    [[ "${#POSITIONAL[@]}" -eq 2 ]] || die "Usage: archive2tape get ARCHIVE_DIR TARGET_DIR --project PROJECT [--work WORK_DIR]"
    [[ -n "$PROJECT" ]] || die "--project is required for get."
    local archive_ns="${POSITIONAL[0]}" target_dir="${POSITIONAL[1]}" work_dir
    archive_ns="$(resolve_archive_dir "$archive_ns")"
    validate_archive_ns "$archive_ns" "$PROJECT"
    work_dir="$(resolve_put_get_work_dir "$archive_ns" "$WORK")"
    validate_work_dir "$work_dir" "$ALLOW_NON_SCRATCH_WORK" "$DRY_RUN"
    POSITIONAL=("$archive_ns" "$work_dir")
    cmd_retrieve
    info "UNPACK_TARGET=$target_dir"
    info "When retrieval is complete and .tar.zst files are present, run:"
    info "  archive2tape unpack $(shell_quote "$work_dir") $(shell_quote "$target_dir")"
}

cmd_unpack() {
    [[ "${#POSITIONAL[@]}" -eq 2 ]] || die "Usage: archive2tape unpack WORK_DIR TARGET_DIR"
    local work_dir="${POSITIONAL[0]}" target_dir="${POSITIONAL[1]}" archive_manifest
    archive_manifest="$work_dir/archive2tape_archive_objects.txt"
    info "WORK_DIR=$work_dir"
    info "TARGET_DIR=$target_dir"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        info "Would unpack these local tar objects:"
        select_local_tar_objects "$work_dir" "$archive_manifest" "$ALL_OBJECTS" || true
        return 0
    fi
    worker_unpack "$work_dir" "$target_dir" "$archive_manifest" "$ALL_OBJECTS"
}

case "$COMMAND" in
    put) cmd_put ;;
    pack) cmd_pack ;;
    archive) cmd_archive ;;
    retrieve) cmd_retrieve ;;
    get) cmd_get ;;
    unpack) cmd_unpack ;;
esac
