#!/usr/bin/env bash
set -euo pipefail

VERSION="0.2.0"
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)/$(basename "${BASH_SOURCE[0]}")"
DEFAULT_INCLUDES=("*.nc" "*.zarr" "*.grb" "*.grib" "*.grb2" "*.grib2")
ONE_GIB=$((1024 * 1024 * 1024))
TEN_GIB=$((10 * ONE_GIB))
TWO_HUNDRED_GIB=$((200 * ONE_GIB))
THREE_TIB=$((3 * 1024 * ONE_GIB))

die() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
warn() { printf 'WARNING: %s\n' "$*" >&2; }
info() { printf '%s\n' "$*"; }

strip_sbatch_job_id() {
    local j="${1:-}"
    j="${j//[$'\t\r\n ']}"
    j="${j%%;*}"
    printf '%s\n' "$j"
}

require_sbatch_job_id() {
    local stage="$1" raw="$2" num
    raw="$(strip_sbatch_job_id "$raw")"
    num="${raw%%.*}"
    [[ "$num" =~ ^[1-9][0-9]*$ ]] ||
        die "Slurm job submission failed for ${stage}: missing or invalid job id (parsed '${raw:-empty}'). Re-check Slurm (--account matches an account you belong to; often same as PROJECT) and partitions (PACK_PARTITION/ARCHIVE_PARTITION/RETRIEVE_PARTITION)."
}

default_slurm_log_dir() { printf '%s/.slurm\n' "${1%/}"; }

usage() {
    cat <<'EOF'
Usage:
  archive2tape put SOURCE_DIR ARCHIVE_DIR --project PROJECT [--work WORK_DIR] [--config FILE]
  archive2tape get ARCHIVE_DIR TARGET_DIR --project PROJECT [--work WORK_DIR] [--config FILE]

Stage commands:
  archive2tape pack SOURCE_DIR WORK_DIR --project PROJECT
  archive2tape archive WORK_DIR ARCHIVE_DIR --project PROJECT
  archive2tape retrieve ARCHIVE_DIR WORK_DIR --project PROJECT
  archive2tape unpack WORK_DIR TARGET_DIR

Common options:
  --config FILE                 Read defaults from archive2tape.conf-style KEY=VALUE file
  --project PROJECT              Must equal first segment after /arch/ in ARCHIVE_DIR
  --account ACCOUNT              Slurm #SBATCH --account; defaults to PROJECT
  --work WORK_DIR                Work dir for put/get; defaults to $GRAVEYARD/<dataset>
  --include GLOB                 Add selected pattern; defaults include nc, zarr, grib
  --include-hidden               Allow hidden paths when selecting files
  --dry-run                      Print plan without submitting or decompressing
  --run-now                      Run stage worker in current shell
  --allow-non-scratch-work       Allow work dir outside /scratch
  --allow-huge                   Allow selected source plan above 3 TiB
  --overwrite                    Replace existing local compressed/decompressed files
  --log-dir DIR                  Slurm log dir; default WORK_DIR/.slurm
  --help                         Show this help

Beginner workflow:
    PROJECT=ab1234
    archive2tape put model_output_dir "/arch/$PROJECT/$USER/my_run" --project "$PROJECT" --work "$GRAVEYARD/my_run"
    archive2tape get "/arch/$PROJECT/$USER/my_run" model_output_from_archive --project "$PROJECT" --work "$GRAVEYARD/my_run"
EOF
}

shell_quote() { printf '%q' "$1"; }
require_cmd() { command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"; }
line_count() { awk 'END{print NR+0}' "$1"; }
sum_second_column() { awk -F '\t' '{s+=$2} END{printf "%.0f\n", s+0}' "$1"; }
dir_abs() { cd "$1" && pwd -P; }
file_size() { stat -c%s "$1" 2>/dev/null || stat -f%z "$1" 2>/dev/null || echo 0; }
dir_size() { du -sb "$1" 2>/dev/null | awk '{print $1}' || du -sk "$1" | awk '{print $1 * 1024}'; }
utc_now() { date -u +%Y-%m-%dT%H:%M:%SZ; }
trim_ws() { awk '{$1=$1; print}' <<< "$1"; }
expand_config_value() { printf '%s\n' "${1//\$USER/${USER:-}}"; }

human_bytes() {
    awk -v bytes="$1" 'BEGIN {
        split("B KiB MiB GiB TiB PiB", unit)
        value = bytes + 0
        i = 1
        while (value >= 1024 && i < 6) { value /= 1024; i++ }
        if (i == 1) printf "%.0f %s", value, unit[i]
        else printf "%.1f %s", value, unit[i]
    }'
}

archive_project() {
    local ns="$1" rest project
    [[ "$ns" == /arch/*/* ]] || return 1
    rest="${ns#/arch/}"
    project="${rest%%/*}"
    [[ -n "$project" ]] || return 1
    printf '%s\n' "$project"
}

validate_archive_ns() {
    local ns="$1" project="$2" ns_project
    ns_project="$(archive_project "$ns")" || die "ARCHIVE_DIR must look like /arch/<project>/... (got '$ns')."
    [[ -n "$project" ]] || die "--project is required for ARCHIVE_DIR '$ns'."
    [[ "$ns_project" == "$project" ]] || die "--project '$project' does not match ARCHIVE_DIR project '$ns_project'."
}

resolve_archive_dir() {
    local archive_ns="$1"
    if [[ "$archive_ns" == /arch/* ]]; then
        printf '%s\n' "$archive_ns"
    elif [[ -n "$ARCHIVE_ROOT" ]]; then
        printf '%s/%s\n' "${ARCHIVE_ROOT%/}" "$archive_ns"
    else
        printf '%s\n' "$archive_ns"
    fi
}

validate_work_dir() {
    local work_dir="$1" allow="$2" dry_run="$3"
    [[ -n "$work_dir" ]] || die "Missing work directory. Pass --work or set GRAVEYARD."
    if [[ "$work_dir" != /scratch/* && "$allow" -ne 1 ]]; then
        if [[ "$dry_run" -eq 1 ]]; then
            warn "Work dir is outside /scratch: $work_dir"
        else
            die "Work dir must be under /scratch by default. Use --allow-non-scratch-work to override."
        fi
    fi
}

resolve_put_get_work_dir() {
    local archive_ns="$1" explicit_work="$2" dataset
    if [[ -n "$explicit_work" ]]; then
        printf '%s\n' "$explicit_work"
        return
    fi
    dataset="$(basename "${archive_ns%/}")"
    if [[ -n "$WORK_ROOT" ]]; then
        printf '%s/%s\n' "${WORK_ROOT%/}" "$dataset"
        return
    fi
    [[ -n "${GRAVEYARD:-}" ]] || die "Pass --work WORK_DIR, set WORK_ROOT in config, or set GRAVEYARD."
    printf '%s/%s\n' "${GRAVEYARD%/}" "$dataset"
}

compressed_dir() { printf '%s/compressed\n' "${1%/}"; }
retrieved_compressed_dir() { printf '%s/retrieved/compressed\n' "${1%/}"; }
packems_work_dir() { printf '%s/packems\n' "${1%/}"; }
unpackems_work_dir() { printf '%s/unpackems\n' "${1%/}"; }

path_matches_include() {
    local rel="$1" pattern
    for pattern in "${INCLUDES[@]}"; do
        [[ "$rel" == $pattern ]] && return 0
    done
    return 1
}

is_hidden_path() {
    local rel="$1"
    [[ "$rel" == .* || "$rel" == */.* ]]
}

is_under_selected_dir() {
    local rel="$1" selected_dir
    shift || true
    for selected_dir in "$@"; do
        [[ "$rel" == "$selected_dir"/* ]] && return 0
    done
    return 1
}

path_size() {
    local path="$1"
    if [[ -d "$path" ]]; then
        dir_size "$path"
    else
        file_size "$path"
    fi
}

compressed_rel_path() {
    local type="$1" rel="$2"
    if [[ "$type" == dir ]]; then
        printf '%s.tar.zst\n' "$rel"
    else
        printf '%s.zst\n' "$rel"
    fi
}

collect_selected_paths() {
    local source_dir="$1" manifest="$2"
    local rel path type size compressed_rel
    local selected_dirs=()
    : > "$manifest"
    while IFS= read -r -d '' path; do
        rel="${path#./}"
        if ((${#selected_dirs[@]} > 0)) && is_under_selected_dir "$rel" "${selected_dirs[@]}"; then
            continue
        fi
        if [[ "$INCLUDE_HIDDEN" -ne 1 ]] && is_hidden_path "$rel"; then
            continue
        fi
        path_matches_include "$rel" || continue
        if [[ -d "$source_dir/$rel" ]]; then
            type="dir"
            selected_dirs+=("$rel")
        else
            type="file"
        fi
        size="$(path_size "$source_dir/$rel")"
        compressed_rel="$(compressed_rel_path "$type" "$rel")"
        printf '%s\t%s\t%s\t%s\n' "$type" "$size" "$rel" "$compressed_rel" >> "$manifest"
    done < <(
        cd "$source_dir"
        find . -mindepth 1 -print0
    )
}

write_metadata() {
    local metadata="$1" source_dir="$2" archive_ns="$3" project="$4" account="$5" total_bytes="$6"
    {
        printf 'ARCHIVE2TAPE_VERSION=%s\n' "$VERSION"
        printf 'CREATED_UTC=%s\n' "$(utc_now)"
        printf 'PROJECT=%s\n' "$project"
        printf 'ACCOUNT=%s\n' "$account"
        printf 'SOURCE_DIR=%s\n' "$source_dir"
        printf 'SOURCE_BASENAME=%s\n' "$(basename "$source_dir")"
        printf 'ARCHIVE_DIR=%s\n' "$archive_ns"
        printf 'TOTAL_BYTES=%s\n' "$total_bytes"
        printf 'INCLUDE_PATTERNS=%s\n' "${INCLUDES[*]}"
        printf 'COMPRESSED_SUBDIR=compressed\n'
    } > "$metadata"
}

print_size_warnings() {
    local total_bytes="$1" allow_huge="$2"
    if (( total_bytes < ONE_GIB )); then
        warn "Selected source data is below 1 GiB ($(human_bytes "$total_bytes")); tape quota/retrieval may be inefficient."
    elif (( total_bytes < TEN_GIB )); then
        warn "Selected source data is below DKRZ's ideal 10-200 GiB object range ($(human_bytes "$total_bytes"))."
    elif (( total_bytes > TWO_HUNDRED_GIB )); then
        warn "Selected source data is above DKRZ's ideal 10-200 GiB object range ($(human_bytes "$total_bytes")); Packems will split packed objects."
    fi
    if (( total_bytes > THREE_TIB && allow_huge != 1 )); then
        die "Selected source plan is above 3 TiB ($(human_bytes "$total_bytes")). Re-run with --allow-huge if intentional."
    fi
}

prepare_compress_plan() {
    local source_dir="$1" work_dir="$2" archive_ns="$3" project="$4" account="$5" dry_run="$6"
    local manifest metadata total_bytes file_count out_dir
    source_dir="$(dir_abs "$source_dir")"
    out_dir="$(compressed_dir "$work_dir")"
    manifest="$out_dir/archive2tape_manifest.tsv"
    metadata="$out_dir/archive2tape_metadata.env"

    if [[ "$dry_run" -eq 1 ]]; then
        local tmp_dir
        tmp_dir="$(mktemp -d)"
        manifest="$tmp_dir/archive2tape_manifest.tsv"
    else
        mkdir -p "$out_dir"
    fi

    collect_selected_paths "$source_dir" "$manifest"
    file_count="$(line_count "$manifest")"
    [[ "$file_count" -gt 0 ]] || die "No selected files found below '$source_dir'. Add --include PATTERN if needed."
    total_bytes="$(sum_second_column "$manifest")"
    print_size_warnings "$total_bytes" "$ALLOW_HUGE"

    if [[ "$dry_run" -ne 1 ]]; then
        write_metadata "$metadata" "$source_dir" "$archive_ns" "$project" "$account" "$total_bytes"
    fi

    info "SOURCE_DIR=$source_dir"
    info "WORK_DIR=$work_dir"
    info "COMPRESSED_DIR=$out_dir"
    [[ -n "$archive_ns" ]] && info "ARCHIVE_DIR=$archive_ns"
    [[ -n "$project" ]] && info "PROJECT=$project"
    [[ -n "$account" ]] && info "ACCOUNT=$account"
    info "SELECTED_ENTRIES=$file_count"
    info "SELECTED_SIZE=$(human_bytes "$total_bytes")"
    info "MANIFEST=$manifest"
}

submit_compress_job() {
    local source_dir="$1" work_dir="$2" log_dir="$3" account="$4" job_id
    mkdir -p "$log_dir"
    require_cmd sbatch
    job_id="$(
        sbatch --parsable \
            --job-name=a2t_compress \
            --partition="${PACK_PARTITION:-compute}" \
            --nodes=1 \
            --ntasks=1 \
            --cpus-per-task="${PACK_CPUS:-8}" \
            --time="${PACK_TIME:-04:00:00}" \
            --account="$account" \
            --mem="${PACK_MEM:-16G}" \
            --output="$log_dir/compress_%j.out" \
            --error="$log_dir/compress_%j.err" <<EOF
#!/usr/bin/env bash
set -euo pipefail
$(shell_quote "$SCRIPT_PATH") __worker_compress $(shell_quote "$source_dir") $(shell_quote "$work_dir") $(shell_quote "$OVERWRITE")
EOF
    )"
    printf '%s\n' "${job_id%%;*}"
}

submit_packems_job() {
    local work_dir="$1" archive_ns="$2" account="$3" dependency="${4:-}" job_id dep_args=()
    local log_dir="${5:-$(default_slurm_log_dir "$work_dir")}" dataset
    mkdir -p "$log_dir"
    require_cmd sbatch
    dataset="$(basename "${archive_ns%/}")"
    [[ -n "$dependency" ]] && dep_args=(--dependency="afterok:$dependency")
    job_id="$(
        sbatch --parsable \
            "${dep_args[@]}" \
            --job-name=a2t_packems \
            --partition="${ARCHIVE_PARTITION:-shared}" \
            --nodes=1 \
            --ntasks=1 \
            --cpus-per-task="${PACKEMS_CPUS:-4}" \
            --time="${ARCHIVE_TIME:-08:00:00}" \
            --account="$account" \
            --mem="${ARCHIVE_MEM:-8G}" \
            --output="$log_dir/packems_%j.out" \
            --error="$log_dir/packems_%j.err" <<EOF
#!/usr/bin/env bash
set -euo pipefail
$(shell_quote "$SCRIPT_PATH") __worker_packems_archive $(shell_quote "$work_dir") $(shell_quote "$archive_ns") $(shell_quote "$dataset")
EOF
    )"
    printf '%s\n' "${job_id%%;*}"
}

submit_unpackems_job() {
    local archive_ns="$1" work_dir="$2" log_dir="$3" account="$4" job_id dataset
    mkdir -p "$log_dir"
    require_cmd sbatch
    dataset="$(basename "${archive_ns%/}")"
    job_id="$(
        sbatch --parsable \
            --job-name=a2t_unpackems \
            --partition="${RETRIEVE_PARTITION:-shared}" \
            --nodes=1 \
            --ntasks=1 \
            --cpus-per-task="${UNPACKEMS_CPUS:-4}" \
            --time="${RETRIEVE_TIME:-08:00:00}" \
            --account="$account" \
            --mem="${RETRIEVE_MEM:-8G}" \
            --output="$log_dir/unpackems_%j.out" \
            --error="$log_dir/unpackems_%j.err" <<EOF
#!/usr/bin/env bash
set -euo pipefail
$(shell_quote "$SCRIPT_PATH") __worker_unpackems $(shell_quote "$archive_ns") $(shell_quote "$work_dir") $(shell_quote "$dataset")
EOF
    )"
    printf '%s\n' "${job_id%%;*}"
}

load_packems() {
    [[ -f /sw/etc/profile.levante ]] && . /sw/etc/profile.levante
    if command -v module >/dev/null 2>&1; then
        module load packems >/dev/null 2>&1 || true
    fi
    require_cmd tapeinit
    require_cmd packems
    require_cmd unpackems
    tapeinit
}

worker_compress() {
    local source_dir="$1" work_dir="$2" overwrite="$3" manifest out_dir type size rel compressed_rel
    local src dst tmp threads parent name
    require_cmd tar
    require_cmd zstd
    source_dir="$(dir_abs "$source_dir")"
    out_dir="$(compressed_dir "$work_dir")"
    manifest="$out_dir/archive2tape_manifest.tsv"
    [[ -d "$source_dir" ]] || die "Missing source dir: $source_dir"
    [[ -f "$manifest" ]] || die "Missing manifest: $manifest"
    threads="${SLURM_CPUS_PER_TASK:-1}"
    while IFS=$'\t' read -r type size rel compressed_rel; do
        [[ -n "$rel" ]] || continue
        src="$source_dir/$rel"
        dst="$out_dir/$compressed_rel"
        mkdir -p "$(dirname "$dst")"
        if [[ -e "$dst" && "$overwrite" -ne 1 ]]; then
            die "Compressed object exists: $dst (use --overwrite to replace)"
        fi
        tmp="${dst}.tmp.$$"
        rm -f "$tmp"
        if [[ "$type" == dir ]]; then
            [[ -d "$src" ]] || die "Missing selected directory: $src"
            parent="$(dirname "$src")"
            name="$(basename "$src")"
            tar -C "$parent" -cf - "$name" | zstd -T"$threads" -9 -o "$tmp"
        else
            [[ -f "$src" ]] || die "Missing selected file: $src"
            zstd -T"$threads" -9 -c "$src" > "$tmp"
        fi
        mv "$tmp" "$dst"
        info "COMPRESSED=$dst"
    done < "$manifest"
}

worker_packems_archive() {
    local work_dir="$1" archive_ns="$2" dataset="$3" out_dir pack_dir target max jobs
    out_dir="$(compressed_dir "$work_dir")"
    pack_dir="$(packems_work_dir "$work_dir")"
    [[ -d "$out_dir" ]] || die "Missing compressed staging dir: $out_dir"
    mkdir -p "$pack_dir"
    load_packems
    target="${PACKEMS_TARGET_GB:-100}"
    max="${PACKEMS_MAX_GB:-200}"
    jobs="${PACKEMS_JOBS:-4}"
    (
        cd "$work_dir"
        packems -d "$pack_dir" -S "$archive_ns" -o "$dataset" -t "$target" -m "$max" -j "$jobs" --no-archive compressed
        packems -d "$pack_dir" -S "$archive_ns" -o "$dataset" -t "$target" -m "$max" -j "$jobs" --archive-only compressed
    )
    info "PACKEMS_INDEX=${archive_ns%/}/INDEX.txt"
}

worker_unpackems() {
    local archive_ns="$1" work_dir="$2" dataset="$3" retrieved work index
    retrieved="$work_dir/retrieved"
    work="$(unpackems_work_dir "$work_dir")"
    index="t:${archive_ns%/}/INDEX.txt"
    mkdir -p "$retrieved" "$work"
    load_packems
    unpackems -i "$index" -d "$retrieved" -w "$work" -f 'compressed/*'
    info "RETRIEVED_COMPRESSED_DIR=$retrieved/compressed"
    info "After retrieval, run:"
    info "  archive2tape unpack $(shell_quote "$work_dir") TARGET_DIR"
}

select_compressed_root() {
    local work_dir="$1" local_root retrieved_root
    local_root="$(compressed_dir "$work_dir")"
    retrieved_root="$(retrieved_compressed_dir "$work_dir")"
    if [[ -f "$retrieved_root/archive2tape_manifest.tsv" ]]; then
        printf '%s\n' "$retrieved_root"
    elif [[ -f "$local_root/archive2tape_manifest.tsv" ]]; then
        printf '%s\n' "$local_root"
    else
        die "No compressed staging manifest found below '$work_dir'. Expected compressed/ or retrieved/compressed/."
    fi
}

worker_decompress() {
    local work_dir="$1" target_dir="$2" overwrite="${3:-0}" root manifest type size rel compressed_rel
    local src dst tmp count=0
    require_cmd tar
    require_cmd zstd
    root="$(select_compressed_root "$work_dir")"
    manifest="$root/archive2tape_manifest.tsv"
    mkdir -p "$target_dir"
    while IFS=$'\t' read -r type size rel compressed_rel; do
        [[ -n "$rel" ]] || continue
        src="$root/$compressed_rel"
        [[ -f "$src" ]] || die "Missing compressed object: $src"
        if [[ "$type" == dir ]]; then
            dst="$target_dir/$rel"
            [[ ! -e "$dst" || "$overwrite" -eq 1 ]] || die "Target directory exists: $dst (use --overwrite to replace)"
            zstd -dc "$src" | tar -xf - -C "$target_dir"
        else
            dst="$target_dir/$rel"
            [[ ! -e "$dst" || "$overwrite" -eq 1 ]] || die "Target file exists: $dst (use --overwrite to replace)"
            mkdir -p "$(dirname "$dst")"
            tmp="${dst}.tmp.$$"
            rm -f "$tmp"
            zstd -dc "$src" > "$tmp"
            mv "$tmp" "$dst"
        fi
        count=$((count + 1))
        info "DECOMPRESSED=$dst"
    done < "$manifest"
    [[ "$count" -gt 0 ]] || die "Manifest has no entries: $manifest"
}

dry_run_packems_archive() {
    local work_dir="$1" archive_ns="$2" dataset
    dataset="$(basename "${archive_ns%/}")"
    info "WORK_DIR=$work_dir"
    info "COMPRESSED_DIR=$(compressed_dir "$work_dir")"
    info "ARCHIVE_DIR=$archive_ns"
    info "PACKEMS_INDEX=${archive_ns%/}/INDEX.txt"
    info "Would run:"
    info "  tapeinit"
    info "  packems -d $(shell_quote "$(packems_work_dir "$work_dir")") -S $(shell_quote "$archive_ns") -o $(shell_quote "$dataset") -t ${PACKEMS_TARGET_GB:-100} -m ${PACKEMS_MAX_GB:-200} -j ${PACKEMS_JOBS:-4} --no-archive compressed"
    info "  packems -d $(shell_quote "$(packems_work_dir "$work_dir")") -S $(shell_quote "$archive_ns") -o $(shell_quote "$dataset") -t ${PACKEMS_TARGET_GB:-100} -m ${PACKEMS_MAX_GB:-200} -j ${PACKEMS_JOBS:-4} --archive-only compressed"
}

dry_run_unpackems() {
    local archive_ns="$1" work_dir="$2"
    info "ARCHIVE_DIR=$archive_ns"
    info "WORK_DIR=$work_dir"
    info "RETRIEVED_COMPRESSED_DIR=$(retrieved_compressed_dir "$work_dir")"
    info "Would run:"
    info "  tapeinit"
    info "  unpackems -i t:${archive_ns%/}/INDEX.txt -d $(shell_quote "$work_dir/retrieved") -w $(shell_quote "$(unpackems_work_dir "$work_dir")") -f 'compressed/*'"
}

find_config_arg() {
    local arg
    while [[ $# -gt 0 ]]; do
        arg="$1"
        case "$arg" in
            --config)
                [[ -n "${2:-}" ]] || die "--config requires a value"
                printf '%s\n' "$2"
                return
                ;;
            --config=*)
                printf '%s\n' "${arg#--config=}"
                return
                ;;
        esac
        shift
    done
}

validate_config_value() {
    local key="$1" value="$2" without_user
    [[ "$value" != *'$('* ]] || die "Config key '$key' contains command substitution."
    [[ "$value" != *'`'* ]] || die "Config key '$key' contains backticks."
    [[ "$value" != *';'* && "$value" != *'&&'* && "$value" != *'||'* ]] || die "Config key '$key' contains shell control syntax."
    [[ "$value" != *'|'* && "$value" != *'<'* && "$value" != *'>'* ]] || die "Config key '$key' contains shell redirection or pipe syntax."
    without_user="${value//\$USER/}"
    [[ "$without_user" != *'$'* ]] || die "Config key '$key' uses unsupported variable expansion; only \$USER is allowed."
}

apply_config_key() {
    local key="$1" value="$2"
    [[ -n "$value" ]] || die "Config key '$key' has an empty value."
    value="$(expand_config_value "$value")"
    case "$key" in
        PROJECT) PROJECT="$value" ;;
        ACCOUNT) ACCOUNT="$value" ;;
        WORK_ROOT) WORK_ROOT="$value" ;;
        ARCHIVE_ROOT) ARCHIVE_ROOT="$value" ;;
        INCLUDE_PATTERNS) read -r -a INCLUDES <<< "$value" ;;
        ALLOW_NON_SCRATCH_WORK)
            [[ "$value" == 0 || "$value" == 1 ]] || die "Config key '$key' must be 0 or 1."
            ALLOW_NON_SCRATCH_WORK="$value"
            ;;
        INCLUDE_HIDDEN)
            [[ "$value" == 0 || "$value" == 1 ]] || die "Config key '$key' must be 0 or 1."
            INCLUDE_HIDDEN="$value"
            ;;
        *) die "Unknown config key: $key" ;;
    esac
}

load_config() {
    local config_file="$1" raw_line line key value
    local seen_keys=()
    [[ -f "$config_file" ]] || die "Missing config file: $config_file"
    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        line="${raw_line%%#*}"
        line="$(trim_ws "$line")"
        [[ -z "$line" ]] && continue
        [[ "$line" == *=* ]] || die "Config line must be KEY=VALUE: $raw_line"
        key="$(trim_ws "${line%%=*}")"
        value="$(trim_ws "${line#*=}")"
        if [[ "$value" == \"*\" && "$value" == *\" ]]; then
            value="${value:1:${#value}-2}"
        elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
            value="${value:1:${#value}-2}"
        fi
        [[ "$key" =~ ^[A-Z][A-Z0-9_]*$ ]] || die "Invalid config key: $key"
        if ((${#seen_keys[@]} > 0)) && printf '%s\n' "${seen_keys[@]}" | grep -Fxq "$key"; then
            die "Duplicate config key: $key"
        fi
        seen_keys+=("$key")
        validate_config_value "$key" "$value"
        apply_config_key "$key" "$value"
    done < "$config_file"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
    exit 0
fi

COMMAND="${1:-}"
case "$COMMAND" in
    __worker_compress) shift; worker_compress "$@"; exit ;;
    __worker_packems_archive) shift; worker_packems_archive "$@"; exit ;;
    __worker_unpackems) shift; worker_unpackems "$@"; exit ;;
    __worker_decompress) shift; worker_decompress "$@"; exit ;;
esac

[[ -n "$COMMAND" ]] || { usage; exit 1; }
shift || true

PROJECT=""
ACCOUNT=""
WORK=""
WORK_ROOT=""
ARCHIVE_ROOT=""
CONFIG=""
LOG_DIR=""
DRY_RUN=0
RUN_NOW=0
ALLOW_NON_SCRATCH_WORK=0
ALLOW_HUGE=0
INCLUDE_HIDDEN=0
OVERWRITE=0
INCLUDES=("${DEFAULT_INCLUDES[@]}")
POSITIONAL=()

CONFIG="$(find_config_arg "$@")"
[[ -n "$CONFIG" ]] && load_config "$CONFIG"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --config) CONFIG="${2:-}"; [[ -n "$CONFIG" ]] || die "--config requires a value"; shift 2 ;;
        --config=*) CONFIG="${1#--config=}"; [[ -n "$CONFIG" ]] || die "--config requires a value"; shift ;;
        --project) PROJECT="${2:-}"; [[ -n "$PROJECT" ]] || die "--project requires a value"; shift 2 ;;
        --account) ACCOUNT="${2:-}"; [[ -n "$ACCOUNT" ]] || die "--account requires a value"; shift 2 ;;
        --work) WORK="${2:-}"; [[ -n "$WORK" ]] || die "--work requires a value"; shift 2 ;;
        --log-dir) LOG_DIR="${2:-}"; [[ -n "$LOG_DIR" ]] || die "--log-dir requires a value"; shift 2 ;;
        --include) INCLUDES+=("${2:-}"); [[ -n "${2:-}" ]] || die "--include requires a value"; shift 2 ;;
        --include-hidden) INCLUDE_HIDDEN=1; shift ;;
        --dry-run) DRY_RUN=1; shift ;;
        --run-now) RUN_NOW=1; shift ;;
        --all-objects) shift ;;
        --allow-non-scratch-work) ALLOW_NON_SCRATCH_WORK=1; shift ;;
        --allow-huge) ALLOW_HUGE=1; shift ;;
        --overwrite) OVERWRITE=1; shift ;;
        -h|--help) usage; exit 0 ;;
        --) shift; while [[ $# -gt 0 ]]; do POSITIONAL+=("$1"); shift; done ;;
        --*) die "Unknown option: $1" ;;
        *) POSITIONAL+=("$1"); shift ;;
    esac
done

case "$COMMAND" in
    put|pack|archive|retrieve|get|unpack) ;;
    *) usage; die "Unknown command: $COMMAND" ;;
esac

ACCOUNT="${ACCOUNT:-$PROJECT}"

cmd_pack() {
    [[ "${#POSITIONAL[@]}" -eq 2 ]] || die "Usage: archive2tape pack SOURCE_DIR WORK_DIR --project PROJECT"
    [[ -n "$PROJECT" ]] || die "--project is required for pack."
    local source_dir="${POSITIONAL[0]}" work_dir="${POSITIONAL[1]}" log_dir job_id source_abs
    [[ -d "$source_dir" ]] || die "Missing source dir: $source_dir"
    validate_work_dir "$work_dir" "$ALLOW_NON_SCRATCH_WORK" "$DRY_RUN"
    log_dir="${LOG_DIR:-$(default_slurm_log_dir "$work_dir")}"
    prepare_compress_plan "$source_dir" "$work_dir" "" "$PROJECT" "$ACCOUNT" "$DRY_RUN"
    [[ "$DRY_RUN" -eq 1 ]] && return 0
    source_abs="$(dir_abs "$source_dir")"
    if [[ "$RUN_NOW" -eq 1 ]]; then
        worker_compress "$source_abs" "$work_dir" "$OVERWRITE"
    else
        job_id="$(submit_compress_job "$source_abs" "$work_dir" "$log_dir" "$ACCOUNT")"
        require_sbatch_job_id "compress" "$job_id"
        info "COMPRESS_JOB_ID=$job_id"
        info "LOG_DIR=$log_dir"
    fi
}

cmd_archive() {
    [[ "${#POSITIONAL[@]}" -eq 2 ]] || die "Usage: archive2tape archive WORK_DIR ARCHIVE_DIR --project PROJECT"
    [[ -n "$PROJECT" ]] || die "--project is required for archive."
    local work_dir="${POSITIONAL[0]}" archive_ns="${POSITIONAL[1]}" log_dir job_id
    archive_ns="$(resolve_archive_dir "$archive_ns")"
    validate_archive_ns "$archive_ns" "$PROJECT"
    validate_work_dir "$work_dir" "$ALLOW_NON_SCRATCH_WORK" "$DRY_RUN"
    log_dir="${LOG_DIR:-$(default_slurm_log_dir "$work_dir")}"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        dry_run_packems_archive "$work_dir" "$archive_ns"
        return 0
    fi
    [[ -d "$(compressed_dir "$work_dir")" ]] || die "Missing compressed staging dir: $(compressed_dir "$work_dir"). Run archive2tape pack first."
    if [[ "$RUN_NOW" -eq 1 ]]; then
        worker_packems_archive "$work_dir" "$archive_ns" "$(basename "${archive_ns%/}")"
    else
        job_id="$(submit_packems_job "$work_dir" "$archive_ns" "$ACCOUNT" "" "$log_dir")"
        require_sbatch_job_id "packems" "$job_id"
        info "PACKEMS_JOB_ID=$job_id"
        info "LOG_DIR=$log_dir"
    fi
}

cmd_put() {
    [[ "${#POSITIONAL[@]}" -eq 2 ]] || die "Usage: archive2tape put SOURCE_DIR ARCHIVE_DIR --project PROJECT [--work WORK_DIR]"
    [[ -n "$PROJECT" ]] || die "--project is required for put."
    local source_dir="${POSITIONAL[0]}" archive_ns="${POSITIONAL[1]}" work_dir log_dir compress_job packems_job source_abs
    [[ -d "$source_dir" ]] || die "Missing source dir: $source_dir"
    archive_ns="$(resolve_archive_dir "$archive_ns")"
    validate_archive_ns "$archive_ns" "$PROJECT"
    work_dir="$(resolve_put_get_work_dir "$archive_ns" "$WORK")"
    validate_work_dir "$work_dir" "$ALLOW_NON_SCRATCH_WORK" "$DRY_RUN"
    log_dir="${LOG_DIR:-$(default_slurm_log_dir "$work_dir")}"
    prepare_compress_plan "$source_dir" "$work_dir" "$archive_ns" "$PROJECT" "$ACCOUNT" "$DRY_RUN"
    [[ "$DRY_RUN" -eq 1 ]] && return 0
    source_abs="$(dir_abs "$source_dir")"
    if [[ "$RUN_NOW" -eq 1 ]]; then
        worker_compress "$source_abs" "$work_dir" "$OVERWRITE"
        worker_packems_archive "$work_dir" "$archive_ns" "$(basename "${archive_ns%/}")"
    else
        compress_job="$(submit_compress_job "$source_abs" "$work_dir" "$log_dir" "$ACCOUNT")"
        require_sbatch_job_id "compress" "$compress_job"
        packems_job="$(submit_packems_job "$work_dir" "$archive_ns" "$ACCOUNT" "$compress_job" "$log_dir")"
        require_sbatch_job_id "packems" "$packems_job"
        info "COMPRESS_JOB_ID=$compress_job"
        info "PACKEMS_JOB_ID=$packems_job"
        info "PACKEMS_DEPENDENCY=afterok:$compress_job"
        info "LOG_DIR=$log_dir"
    fi
}

cmd_retrieve() {
    [[ "${#POSITIONAL[@]}" -eq 2 ]] || die "Usage: archive2tape retrieve ARCHIVE_DIR WORK_DIR --project PROJECT"
    [[ -n "$PROJECT" ]] || die "--project is required for retrieve."
    local archive_ns="${POSITIONAL[0]}" work_dir="${POSITIONAL[1]}" log_dir job_id
    archive_ns="$(resolve_archive_dir "$archive_ns")"
    validate_archive_ns "$archive_ns" "$PROJECT"
    validate_work_dir "$work_dir" "$ALLOW_NON_SCRATCH_WORK" "$DRY_RUN"
    log_dir="${LOG_DIR:-$(default_slurm_log_dir "$work_dir")}"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        dry_run_unpackems "$archive_ns" "$work_dir"
        return 0
    fi
    if [[ "$RUN_NOW" -eq 1 ]]; then
        worker_unpackems "$archive_ns" "$work_dir" "$(basename "${archive_ns%/}")"
    else
        job_id="$(submit_unpackems_job "$archive_ns" "$work_dir" "$log_dir" "$ACCOUNT")"
        require_sbatch_job_id "unpackems" "$job_id"
        info "UNPACKEMS_JOB_ID=$job_id"
        info "LOG_DIR=$log_dir"
    fi
    info "When retrieval is complete, run:"
    info "  archive2tape unpack $(shell_quote "$work_dir") TARGET_DIR"
}

cmd_get() {
    [[ "${#POSITIONAL[@]}" -eq 2 ]] || die "Usage: archive2tape get ARCHIVE_DIR TARGET_DIR --project PROJECT [--work WORK_DIR]"
    [[ -n "$PROJECT" ]] || die "--project is required for get."
    local archive_ns="${POSITIONAL[0]}" target_dir="${POSITIONAL[1]}" work_dir
    archive_ns="$(resolve_archive_dir "$archive_ns")"
    validate_archive_ns "$archive_ns" "$PROJECT"
    work_dir="$(resolve_put_get_work_dir "$archive_ns" "$WORK")"
    validate_work_dir "$work_dir" "$ALLOW_NON_SCRATCH_WORK" "$DRY_RUN"
    POSITIONAL=("$archive_ns" "$work_dir")
    cmd_retrieve
    info "UNPACK_TARGET=$target_dir"
    info "When retrieval is complete, run:"
    info "  archive2tape unpack $(shell_quote "$work_dir") $(shell_quote "$target_dir")"
}

cmd_unpack() {
    [[ "${#POSITIONAL[@]}" -eq 2 ]] || die "Usage: archive2tape unpack WORK_DIR TARGET_DIR"
    local work_dir="${POSITIONAL[0]}" target_dir="${POSITIONAL[1]}"
    info "WORK_DIR=$work_dir"
    info "TARGET_DIR=$target_dir"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        info "Would decompress from:"
        select_compressed_root "$work_dir"
        return 0
    fi
    worker_decompress "$work_dir" "$target_dir" "$OVERWRITE"
}

case "$COMMAND" in
    put) cmd_put ;;
    pack) cmd_pack ;;
    archive) cmd_archive ;;
    retrieve) cmd_retrieve ;;
    get) cmd_get ;;
    unpack) cmd_unpack ;;
esac
